{
  "name": "openclaw-ui-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:proxy dev:frontend",
    "dev:frontend": "npm --prefix apps/frontend run dev",
    "dev:proxy": "npm --prefix apps/proxy run dev",
    "build": "run-s build:proxy build:frontend",
    "build:frontend": "npm --prefix apps/frontend run build",
    "build:proxy": "npm --prefix apps/proxy run build",
    "type-check": "run-s type-check:proxy type-check:frontend",
    "type-check:frontend": "npm --prefix apps/frontend run type-check",
    "type-check:proxy": "npm --prefix apps/proxy run type-check",
    "lint": "run-s lint:proxy lint:frontend",
    "lint:frontend": "npm --prefix apps/frontend run lint",
    "lint:proxy": "npm --prefix apps/proxy run lint"
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
